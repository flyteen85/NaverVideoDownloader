{
  "manifest_version": 3,
  "name": "네이버 동영상 다운로더",
  "version": "1.0.3",
  "description": "네이버 블로그·카페·포스트의 동영상을 자동 감지하여 화질별로 바로 다운로드합니다.",
  "minimum_chrome_version": "114",
  "permissions": ["downloads", "storage", "alarms"],
  "host_permissions": ["*://*.naver.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "네이버 동영상 다운로더 (클릭하여 패널 열기)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.naver.com/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://*.naver.com/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.naver.com/*"],
      "js": ["content/panel.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/popup.html", "popup/popup.css", "popup/popup.js", "icons/*"],
      "matches": ["*://*.naver.com/*"]
    }
  ]
}
